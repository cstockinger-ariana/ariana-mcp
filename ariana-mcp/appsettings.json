{
  "Serilog": {
    "Using": [ "Serilog.Sinks.Console" ],
    "MinimumLevel": {
      "Default": "Information",
      "Override": {
        "Microsoft": "Warning",
        "Microsoft.AspNetCore": "Warning",
        "Microsoft.Hosting.Lifetime": "Information",
        "ModelContextProtocol": "Information"
      }
    },
    "Enrich": [ "FromLogContext" ],
    "WriteTo": [
      { "Name": "Console" }
    ]
  },
  "Logging": {
    "LogLevel": {
      "Default": "Debug",
      "Microsoft.AspNetCore": "Information",
      "Microsoft.Hosting.Lifetime": "Information",
      "ModelContextProtocol": "Debug"
    }
  },
  "AraianLab": {
    "User": "${ARIANALAB_USER}",
    "Password": "${ARIANALAB_PASSWORD}",
    "BaseUrl": "${ARIANALAB_BASE_URL?https://klims.labor-kneissler.de/}"
  }
}
